{
	"info": {
		"name": "Proyecto E-Commerce MS 2026",
		"description": "Collection completa para probar todos los microservicios del Proyecto E-Commerce de Tecnología 2026.\n\n**Cómo usarla:**\n1. Importa también el Environment `MS2026-Local.postman_environment.json`\n2. Selecciónalo arriba a la derecha\n3. Ejecuta primero `AUTH > Login` (auto-guarda el token)\n4. Luego puedes ejecutar cualquier otro request",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{ "key": "token", "value": "{{token}}", "type": "string" }
		]
	},
	"item": [
		{
			"name": "🔐 AUTH",
			"item": [
				{
					"name": "Register (admin)",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}" },
						"url": { "raw": "{{auth_url}}/auth/register", "host": ["{{auth_url}}"], "path": ["auth", "register"] }
					}
				},
				{
					"name": "Login (auto-guarda token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const response = pm.response.json();",
									"if (response.accessToken) {",
									"    pm.environment.set('token', response.accessToken);",
									"    console.log('Token guardado:', response.accessToken.substring(0, 30) + '...');",
									"} else {",
									"    console.log('No se recibió token. Respuesta:', response);",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}" },
						"url": { "raw": "{{auth_url}}/auth/login", "host": ["{{auth_url}}"], "path": ["auth", "login"] }
					}
				}
			]
		},
		{
			"name": "📚 CATÁLOGO",
			"item": [
				{
					"name": "Listar categorías",
					"request": {
						"method": "GET",
						"url": { "raw": "{{catalogo_url}}/api/v1/categorias", "host": ["{{catalogo_url}}"], "path": ["api", "v1", "categorias"] }
					}
				},
				{
					"name": "Obtener categoría por ID",
					"request": {
						"method": "GET",
						"url": { "raw": "{{catalogo_url}}/api/v1/categorias/1", "host": ["{{catalogo_url}}"], "path": ["api", "v1", "categorias", "1"] }
					}
				},
				{
					"name": "Crear categoría",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Laptops\",\n  \"descripcion\": \"Equipos portátiles de alto rendimiento\"\n}" },
						"url": { "raw": "{{catalogo_url}}/api/v1/categorias", "host": ["{{catalogo_url}}"], "path": ["api", "v1", "categorias"] }
					}
				},
				{
					"name": "Actualizar categoría",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Laptops Gaming\",\n  \"descripcion\": \"Equipos portátiles para juegos\"\n}" },
						"url": { "raw": "{{catalogo_url}}/api/v1/categorias/1", "host": ["{{catalogo_url}}"], "path": ["api", "v1", "categorias", "1"] }
					}
				},
				{
					"name": "Eliminar categoría",
					"request": {
						"method": "DELETE",
						"url": { "raw": "{{catalogo_url}}/api/v1/categorias/1", "host": ["{{catalogo_url}}"], "path": ["api", "v1", "categorias", "1"] }
					}
				},
				{
					"name": "Instancia",
					"request": {
						"method": "GET",
						"url": { "raw": "{{catalogo_url}}/api/v1/catalogo/instancia", "host": ["{{catalogo_url}}"], "path": ["api", "v1", "catalogo", "instancia"] }
					}
				}
			]
		},
		{
			"name": "📦 PRODUCTO",
			"item": [
				{
					"name": "Listar productos",
					"request": {
						"method": "GET",
						"url": { "raw": "{{producto_url}}/api/v1/productos", "host": ["{{producto_url}}"], "path": ["api", "v1", "productos"] }
					}
				},
				{
					"name": "Obtener producto por ID",
					"request": {
						"method": "GET",
						"url": { "raw": "{{producto_url}}/api/v1/productos/1", "host": ["{{producto_url}}"], "path": ["api", "v1", "productos", "1"] }
					}
				},
				{
					"name": "🌟 Detalle producto (Feign + Circuit Breaker)",
					"request": {
						"method": "GET",
						"url": { "raw": "{{producto_url}}/api/v1/productos/detalle/1", "host": ["{{producto_url}}"], "path": ["api", "v1", "productos", "detalle", "1"] }
					}
				},
				{
					"name": "Crear producto",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Laptop HP Pavilion\",\n  \"descripcion\": \"15.6 pulgadas, 16GB RAM, 512GB SSD\",\n  \"idCategoria\": 1,\n  \"precio\": 2500.00,\n  \"stock\": 20,\n  \"activo\": true,\n  \"sku\": \"LAP-HP-001\"\n}" },
						"url": { "raw": "{{producto_url}}/api/v1/productos", "host": ["{{producto_url}}"], "path": ["api", "v1", "productos"] }
					}
				},
				{
					"name": "Actualizar producto",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Laptop HP Pavilion Pro\",\n  \"descripcion\": \"32GB RAM, 1TB SSD\",\n  \"idCategoria\": 1,\n  \"precio\": 2999.00,\n  \"stock\": 10,\n  \"activo\": true,\n  \"sku\": \"LAP-HP-002\"\n}" },
						"url": { "raw": "{{producto_url}}/api/v1/productos/1", "host": ["{{producto_url}}"], "path": ["api", "v1", "productos", "1"] }
					}
				},
				{
					"name": "Eliminar producto",
					"request": {
						"method": "DELETE",
						"url": { "raw": "{{producto_url}}/api/v1/productos/1", "host": ["{{producto_url}}"], "path": ["api", "v1", "productos", "1"] }
					}
				},
				{
					"name": "Instancia",
					"request": {
						"method": "GET",
						"url": { "raw": "{{producto_url}}/api/v1/producto/instancia", "host": ["{{producto_url}}"], "path": ["api", "v1", "producto", "instancia"] }
					}
				}
			]
		},
		{
			"name": "🛒 PEDIDO",
			"item": [
				{
					"name": "Listar pedidos",
					"request": {
						"method": "GET",
						"url": { "raw": "{{pedido_url}}/api/v1/pedidos", "host": ["{{pedido_url}}"], "path": ["api", "v1", "pedidos"] }
					}
				},
				{
					"name": "Obtener pedido por ID",
					"request": {
						"method": "GET",
						"url": { "raw": "{{pedido_url}}/api/v1/pedidos/1", "host": ["{{pedido_url}}"], "path": ["api", "v1", "pedidos", "1"] }
					}
				},
				{
					"name": "🌟 Crear pedido (registra pago automatico)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"userId\": 1,\n  \"cliente\": \"admin\",\n  \"estado\": \"PENDIENTE\",\n  \"observacion\": \"Pedido de demo\",\n  \"direccionEnvio\": \"Av. Universitaria 123, Lima\",\n  \"items\": [{\"productoId\": 1, \"cantidad\": 1}]\n}" },
						"url": { "raw": "{{pedido_url}}/api/v1/pedidos", "host": ["{{pedido_url}}"], "path": ["api", "v1", "pedidos"] }
					}
				},
				{
					"name": "Actualizar pedido",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"userId\": 1,\n  \"cliente\": \"admin\",\n  \"estado\": \"PAGADO\",\n  \"observacion\": \"Confirmado\",\n  \"direccionEnvio\": \"Jr. Lima 456\",\n  \"items\": [{\"productoId\": 1, \"cantidad\": 1}]\n}" },
						"url": { "raw": "{{pedido_url}}/api/v1/pedidos/1", "host": ["{{pedido_url}}"], "path": ["api", "v1", "pedidos", "1"] }
					}
				},
				{
					"name": "Eliminar pedido",
					"request": {
						"method": "DELETE",
						"url": { "raw": "{{pedido_url}}/api/v1/pedidos/1", "host": ["{{pedido_url}}"], "path": ["api", "v1", "pedidos", "1"] }
					}
				},
				{
					"name": "Instancia",
					"request": {
						"method": "GET",
						"url": { "raw": "{{pedido_url}}/api/v1/pedido/instancia", "host": ["{{pedido_url}}"], "path": ["api", "v1", "pedido", "instancia"] }
					}
				}
			]
		},
		{
			"name": "💳 PAGO",
			"item": [
				{
					"name": "Listar pagos",
					"request": {
						"method": "GET",
						"url": { "raw": "{{pago_url}}/api/v1/pagos", "host": ["{{pago_url}}"], "path": ["api", "v1", "pagos"] }
					}
				},
				{
					"name": "Obtener pago por ID",
					"request": {
						"method": "GET",
						"url": { "raw": "{{pago_url}}/api/v1/pagos/1", "host": ["{{pago_url}}"], "path": ["api", "v1", "pagos", "1"] }
					}
				},
				{
					"name": "Crear pago",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"idPedido\": 1,\n  \"monto\": 2500.00,\n  \"metodo\": \"TARJETA\",\n  \"estado\": \"APROBADO\",\n  \"referenciaTransaccion\": \"TXN-001\"\n}" },
						"url": { "raw": "{{pago_url}}/api/v1/pagos", "host": ["{{pago_url}}"], "path": ["api", "v1", "pagos"] }
					}
				},
				{
					"name": "Actualizar pago",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"idPedido\": 1,\n  \"monto\": 2500.00,\n  \"metodo\": \"YAPE\",\n  \"estado\": \"APROBADO\",\n  \"referenciaTransaccion\": \"TXN-002\"\n}" },
						"url": { "raw": "{{pago_url}}/api/v1/pagos/1", "host": ["{{pago_url}}"], "path": ["api", "v1", "pagos", "1"] }
					}
				},
				{
					"name": "Eliminar pago",
					"request": {
						"method": "DELETE",
						"url": { "raw": "{{pago_url}}/api/v1/pagos/1", "host": ["{{pago_url}}"], "path": ["api", "v1", "pagos", "1"] }
					}
				},
				{
					"name": "Instancia",
					"request": {
						"method": "GET",
						"url": { "raw": "{{pago_url}}/api/v1/pago/instancia", "host": ["{{pago_url}}"], "path": ["api", "v1", "pago", "instancia"] }
					}
				}
			]
		},
		{
			"name": "📊 ACTUATOR (Health/Metrics)",
			"item": [
				{ "name": "Auth - Health", "request": { "method": "GET", "auth": { "type": "noauth" }, "url": { "raw": "{{auth_url}}/actuator/health", "host": ["{{auth_url}}"], "path": ["actuator", "health"] } } },
				{ "name": "Catálogo - Health", "request": { "method": "GET", "auth": { "type": "noauth" }, "url": { "raw": "{{catalogo_url}}/actuator/health", "host": ["{{catalogo_url}}"], "path": ["actuator", "health"] } } },
				{ "name": "Producto - Health", "request": { "method": "GET", "auth": { "type": "noauth" }, "url": { "raw": "{{producto_url}}/actuator/health", "host": ["{{producto_url}}"], "path": ["actuator", "health"] } } },
				{ "name": "Pedido - Health", "request": { "method": "GET", "auth": { "type": "noauth" }, "url": { "raw": "{{pedido_url}}/actuator/health", "host": ["{{pedido_url}}"], "path": ["actuator", "health"] } } },
				{ "name": "Pago - Health", "request": { "method": "GET", "auth": { "type": "noauth" }, "url": { "raw": "{{pago_url}}/actuator/health", "host": ["{{pago_url}}"], "path": ["actuator", "health"] } } },
				{ "name": "Gateway - Health", "request": { "method": "GET", "auth": { "type": "noauth" }, "url": { "raw": "{{gateway_url}}/actuator/health", "host": ["{{gateway_url}}"], "path": ["actuator", "health"] } } }
			]
		},
		{
			"name": "🌐 VÍA GATEWAY (puerto 7091)",
			"item": [
				{
					"name": "Login vía Gateway",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const response = pm.response.json();",
									"if (response.accessToken) { pm.environment.set('token', response.accessToken); }"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}" },
						"url": { "raw": "{{gateway_url}}/auth/login", "host": ["{{gateway_url}}"], "path": ["auth", "login"] }
					}
				},
				{ "name": "Categorías vía Gateway", "request": { "method": "GET", "url": { "raw": "{{gateway_url}}/api/v1/categorias", "host": ["{{gateway_url}}"], "path": ["api", "v1", "categorias"] } } },
				{ "name": "Productos vía Gateway", "request": { "method": "GET", "url": { "raw": "{{gateway_url}}/api/v1/productos", "host": ["{{gateway_url}}"], "path": ["api", "v1", "productos"] } } },
				{ "name": "Pedidos vía Gateway", "request": { "method": "GET", "url": { "raw": "{{gateway_url}}/api/v1/pedidos", "host": ["{{gateway_url}}"], "path": ["api", "v1", "pedidos"] } } },
				{ "name": "Pagos vía Gateway", "request": { "method": "GET", "url": { "raw": "{{gateway_url}}/api/v1/pagos", "host": ["{{gateway_url}}"], "path": ["api", "v1", "pagos"] } } }
			]
		}
	],
	"variable": []
}
