FROM maven:3.9.9-eclipse-temurin-17 AS build
WORKDIR /app

COPY config-server/pom.xml ./pom.xml
RUN mvn -q -f pom.xml dependency:go-offline

COPY config-server/src ./src
RUN mvn -q -f pom.xml clean package -DskipTests

FROM eclipse-temurin:17-jre
WORKDIR /app

COPY --from=build /app/target/*.jar app.jar
COPY config-repo /config-repo

ENV SPRING_PROFILES_ACTIVE=native
ENV CONFIG_REPO_LOCATION=file:/config-repo

EXPOSE 7071

CMD ["sh", "-c", "java -jar app.jar --server.port=${PORT:-7071}"]
